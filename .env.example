# WorkLang AI — environment variable template.
#
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# `.env` is gitignored; only `.env.example` (with no secrets) is committed.

# PostgreSQL connection used by the app at runtime (Prisma + pg driver adapter).
# On Supabase this is the pooled (PgBouncer, port 6543) connection string.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/worklang_ai?schema=public"

# Direct (non-pooled) connection used by the Prisma CLI for migrations and
# validate (see prisma.config.ts). On Supabase this is the direct (port 5432)
# connection string; locally it can be the same as DATABASE_URL.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DIRECT_URL="postgresql://USER:PASSWORD@localhost:5432/worklang_ai?schema=public"

# --- LLM provider (Groq) — Phase 7. Server-side only; never expose to client. ---
# Secret API key. Leave blank here; put the real value only in local .env.
GROQ_API_KEY=
# Primary model: strict structured outputs, preferred for grammar/CEFR/writing.
GROQ_MODEL_PRIMARY=openai/gpt-oss-120b
# Fallback model: same strict structured-output path, cheaper/faster.
GROQ_MODEL_FALLBACK=openai/gpt-oss-20b
